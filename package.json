{
  "name": "frogcord",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "electron:start": "electron .",
    "electron:build": "electron-builder build --config.asar=false",
    "dev:all": "./start-frogcord.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.frogcord.app",
    "productName": "FrogCord",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "package.json",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/public/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "frontend/public/logo.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^1.7.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  }
}
